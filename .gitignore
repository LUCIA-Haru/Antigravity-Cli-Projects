# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   According to [1], it's better to not commit it (since it can be specific to a developer).
#   [1] https://github.com/pyenv/pyenv#checking-in-your-python-version
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a library, you might want to ignore it.
#   [2] https://pipenv.pypa.io/en/latest/advanced/#pipfile-vs-setup-py
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains specific versions of dependencies
#   and might be wanted or not.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains specific versions of dependencies
#   and might be wanted or not.
#pdm.lock

# PEP 582; project packages directory (e.g. pdm)
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath vars
*.sage.py

